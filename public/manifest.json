{
  "manifest_version": 3,
  "name": "Pegboard",
  "version": "1.0.0",
  "description": "Personal new tab launcher with sections, badges, and search",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": ["storage", "favicon", "contextMenus"],
  "omnibox": { "keyword": "pin" },
  "background": {
    "service_worker": "background.js"
  },
  "icons": { "16": "icon-16.png" }
}
